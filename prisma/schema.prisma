// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id      String   @id @default(uuid())
  sid     String   @unique
  data    String
  expiresAt DateTime

  @@index([expiresAt])
  @@map("session")

}

model User {
  id          String  @id @default(uuid())
  username    String @unique
  fullname    String
  password    String

  @@map("user")
  items Item[]
}

enum ItemType {
  file
  folder

  @@map("itemType")
}

model Item {
   id         String  @id @default(uuid())
   user       User @relation(fields: [userId], references: [id])
   userId     String
   type       ItemType
   parentId   String?
   filePath   String?
   name       String

   parent     Item?  @relation("FolderContents",fields: [parentId], references: [id])
   children   Item[] @relation("FolderContents")

   @@map("item")
}